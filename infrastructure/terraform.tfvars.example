# Copy this file to terraform.tfvars and fill in your values
# terraform.tfvars is git-ignored — never commit it

aws_region     = "ap-south-1"
project_name   = "shopsphere"
environment    = "dev"

# Get this from: aws sts get-caller-identity --query Account --output text
aws_account_id = "123456789012"

# Your GitHub repo in owner/repo format
github_repo    = "saurabhg4356/shopsphere"

# Node sizing
node_instance_type = "t3.medium"
node_desired_count = 2
node_min_count     = 1
node_max_count     = 4

# DB sizing
db_instance_class  = "db.t3.micro"

# db_password is NOT set here — use environment variable instead:
# export TF_VAR_db_password='YourStrongPassword123!'